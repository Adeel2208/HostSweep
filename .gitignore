# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Results and data (don't commit large files)
results/
data/*.fastq.gz
data/*.fq.gz
*.bam
*.sam
*.bai

# Reference genomes (too large for git)
reference/*.fasta
reference/*.fa
reference/*.fna
reference/indices/*.mmi
reference/indices/*.bt2
reference/indices/*.bt2l

# Keep structure but not content
!reference/.gitkeep
!data/.gitkeep

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temporary files
temp/
tmp/
*.tmp

# Backup files
*.backup
*.backup[0-9]
*.bak
